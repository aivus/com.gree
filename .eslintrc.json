{
    "extends": "athom",
    "rules": {
        "no-use-before-define": ["error", { "functions": false }],
        "no-console": "off",
        "node/no-unpublished-require": ["error", { "allowModules": ["homey"]}],
        "indent": ["error", 4, { "SwitchCase": 1 }]
    },
    "overrides": [
        {
            "files": ["test/**/*.js"],
            "env": {
                "jest": true
            },
            "rules": {
                "node/no-unpublished-require": "off",
                "mocha/no-mocha-arrows": "off",
                "global-require": "off"
            }
        }
    ]
}
